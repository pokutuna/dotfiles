#!/bin/bash
# Sort tmux windows by pane's current directory path

set -e

# Remember the current window to return after sorting
current_window=$(tmux display-message -p '#{window_id}')

# Get sorted list: "window_index path"
sorted=$(tmux list-windows -F '#{window_index} #{pane_current_path}' | sort -t' ' -k2 -f)

# Collect original indices in sorted order
indices=()
while read -r idx _name; do
  indices+=("$idx")
done <<< "$sorted"

# Move each window to a high temporary index to avoid collision, in sorted order
tmp=10000
for i in "${!indices[@]}"; do
  tmux move-window -s "${indices[$i]}" -t "$((tmp + i))"
done

# Move them back to sequential indices
for i in "${!indices[@]}"; do
  tmux move-window -s "$((tmp + i))" -t "$((i + 1))"
done

# Return to the original window
tmux select-window -t "$current_window"
